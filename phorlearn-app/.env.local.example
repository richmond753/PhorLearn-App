# Copy this file to ".env.local" and fill in the values.

# ── MySQL connection (your local MySQL Workbench server) ──
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-root-password
MYSQL_DATABASE=phorlearn

# ── Session signing secret (signs the login cookie / JWT) ──
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=replace-with-a-long-random-string

# ── Google Gemini — powers the AI Study Helper on lesson pages ──
# Get a FREE key (no billing) at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
