# Copy this file to ".env.local" and fill in the values.

# ── MySQL connection ──
# Local dev: your MySQL Workbench server (SSL off).
# Production (Render): a cloud MySQL provider's host/credentials with SSL on.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-root-password
MYSQL_DATABASE=phorlearn

# Set MYSQL_SSL=true when connecting to a managed cloud MySQL (TiDB, Aiven,
# Clever Cloud, etc.). Leave unset/false for a local MySQL server.
# MYSQL_SSL=true
# If the provider uses a self-signed certificate chain, also set:
# MYSQL_SSL_REJECT_UNAUTHORIZED=false

# ── Session signing secret (signs the login cookie / JWT) ──
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=replace-with-a-long-random-string

# ── Google Gemini — powers the AI Study Helper on lesson pages ──
# Get a FREE key (no billing) at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
